   "source": [
    "START\n",
    "INPUT price\n",
    "INPUT quantity\n",
    "\n",
    "COMPUTE total = price * quantity\n",
    "PRINT total\n",
    "\n",
    "INPUT payment\n",
    "IF payment >= total THEN\n",
    "COMPUTE change = payment - total\n",
    "PRINT change\n",
    "\n",
    "\n",
    "ELSE\n",
    "PRINT \"Not enough money\"\n",
    "\n",
    "END"
   ]
  }
